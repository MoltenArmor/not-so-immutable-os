#!/bin/sh
set -ue

TMP="$(mktemp -d)"

clean() {
    rm -rf "${TMP}"
}
trap clean EXIT

if [ "$ARCHITECTURE" = "x86-64" ]; then
    QQ_ARCH="amd64"
elif [ "$ARCHITECTURE" = "arm64" ]; then
    QQ_ARCH="arm64"
else
    printf "%s\n" "Not supported arch."
    exit 1
fi

curl -sSL "https://dldir1v6.qq.com/qqfile/qq/QQNT/Linux/QQ_3.2.25_260205_arm64_01.deb" -o "${TMP}/qq.deb"

mkosi-install "${TMP}/qq.deb"
